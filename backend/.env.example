# Google Gemini API Configuration
GEMINI_API_KEY=your_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Firebase Admin SDK — required for audio caching (Firestore + Storage)
# Get these from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=dse-elibrary-75930
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@dse-elibrary-75930.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Optional — defaults to dse-elibrary-75930.firebasestorage.app
# FIREBASE_STORAGE_BUCKET=dse-elibrary-75930.firebasestorage.app
